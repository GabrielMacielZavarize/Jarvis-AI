# Backend principal do Jarvis: gemini-realtime | openai-realtime | openai-compatible-pipeline
JARVIS_BACKEND=gemini-realtime

# Ative a ferramenta de email somente quando quiser usá-la
JARVIS_ENABLE_EMAIL_TOOL=false

# Lista CSV de destinatários autorizados. Se ficar vazia, apenas GMAIL_USER será permitido.
JARVIS_ALLOWED_EMAILS=

# Credenciais LiveKit para os comandos dev/start/connect
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Google Gemini Realtime
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GOOGLE_VOICE=Charon

# OpenAI Realtime
OPENAI_API_KEY=your-openai-api-key
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_VOICE=marin

# Endpoints compatíveis com OpenAI
OPENAI_BASE_URL=
OPENAI_LLM_MODEL=gpt-4.1
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=ash

# Gmail App Password para o fluxo seguro de email
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
